{
  "keywords": {
    "malloc": 6,
    "calloc": 6,
    "realloc": 6,
    "free": 6,
    "->": 5,
    "*": 4,
    "&": 4,
    "volatile": 5,
    "restrict": 5,
    "extern": 3,
    "struct": 3,
    "union": 5,
    "sizeof": 3,
    "#define": -3,
    "atoi": -5,
    "goto": -8,
    "gets": -15
  },
  
  "categories_multipliers": {
    "critical_safety": 10,
    "data_integrity": 5,
    "program_logic": 3,
    "language_standards_compliance": 2,
    "control_flow_integrity": 1.5,
    "maintenance_and_style": 0.2
  },
  
  "linter_warnings": {
    "categories": {
      "critical_safety": {
        "clang-analyzer-unix.Malloc": 100,
        "clang-analyzer-core.NullDereference": 100,
        "clang-analyzer-security.insecureAPI.gets": 100,
        "clang-analyzer-core.uninitialized.ArraySubscript": 100,
        "clang-analyzer-core.StackAddressEscape": 90,
        "clang-analyzer-optin.taint.TaintedAlloc": 90,
        "clang-analyzer-security.insecureAPI.strcpy": 80,
        "bugprone-not-null-terminated-result": 90
      },
      "data_integrity": {
        "clang-analyzer-core.DivideZero": 95,
        "clang-analyzer-core.UndefinedBinaryOperatorResult": 90,
        "clang-diagnostic-integer-overflow": 90,
        "clang-diagnostic-unsequenced": 90,
        "clang-analyzer-core.BitwiseShift": 90,
        "bugprone-sizeof-expression": 85,
        "clang-diagnostic-string-plus-int": 80,
        "bugprone-implicit-widening-of-multiplication-result": 70
      },
      "program_logic": {
        "bugprone-infinite-loop": 95,
        "clang-diagnostic-return-type": 95,
        "clang-diagnostic-memset-transposed-args": 85,
        "bugprone-suspicious-semicolon": 80,
        "clang-diagnostic-format": 80,
        "concurrency-mt-unsafe": 75,
        "bugprone-chained-comparison": 75,
        "bugprone-assignment-in-if-condition": 65
      },
      "language_standards_compliance": {
        "cert-env33-c": 90,
        "cert-msc33-c": 80,
        "cert-msc30-c": 70,
        "cert-msc32-c": 70,
        "cert-msc50-cpp": 70,
        "cert-msc51-cpp": 70,
        "clang-analyzer-optin.portability.UnixAPI": 50,
        "hicpp-no-assembler": 30
      },
      "control_flow_integrity": {
        "bugprone-branch-clone": 65,
        "custom-goto-statement": 50,
        "clang-analyzer-deadcode.DeadStores": 20,
        "readability-misleading-indentation": 70,
        "performance-no-int-to-ptr": 45,
        "clang-diagnostic-dangling-else": 70
