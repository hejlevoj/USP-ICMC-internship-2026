      "maintenance_and_style": {
        "-Wshadow": 40,
        "-Wparentheses": 35,
        "-Wmissing-braces": 30,
        "-Wunused-value": 25,
        "-Wunused-variable": 10,
        "-Wunused-parameter": 5,
        "-Wunused-but-set-variable": 5
      }
