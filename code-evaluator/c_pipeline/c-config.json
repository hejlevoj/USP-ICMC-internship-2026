      "maintenance_and_style": {
        "cppcoreguidelines-init-variables": 35,
        "cppcoreguidelines-avoid-non-const-global-variables": 40,
        "readability-function-cognitive-complexity": 30,
        "misc-unused-parameters": 30,
        "performance-type-promotion-in-math-fn": 30,
        "altera-struct-pack-align": 25,
        "clang-analyzer-optin.performance.Padding": 25,
        "altera-id-dependent-backward-branch": 20
      }
    }
  },
  "compiler_warnings": {
    "categories": {
      "critical_safety": {
        "-Warray-bounds": 100,
        "-Wuse-after-free": 100,
        "-Wreturn-local-addr": 100,
        "-Wnull-dereference": 95,
        "-Wrestrict": 90,
        "-Wnonnull": 85,
        "-Wmain": 80
