        "-Wjump-misses-init": 80,
        "-Wimplicit-fallthrough": 75,
        "-Wmultistatement-macros": 70,
        "-Wempty-body": 55,
        "-Wdangling-else": 55,
        "-Wunknown-pragmas": 35
